# ============================================================
# Taxly — Environment Variables
# Copiază în .env și completează cu valorile reale
# NU commite fișierul .env în git!
# ============================================================

# --- API (apps/api) ---
NODE_ENV=development
PORT=4000
HOST=0.0.0.0
LOG_LEVEL=info

# MongoDB
MONGODB_URI=mongodb://taxly:taxly_dev_pass@localhost:27017/taxly?authSource=admin

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=schimba-asta-cu-un-secret-puternic-de-cel-putin-32-caractere
JWT_REFRESH_SECRET=alt-secret-pentru-refresh-tokens

# Frontend URL (CORS)
FRONTEND_URL=http://localhost:3000

# ANAF e-Factura (Sandbox)
ANAF_API_BASE_URL=https://api.anaf.ro/test/FCTEL/rest
ANAF_CLIENT_ID=
ANAF_CLIENT_SECRET=

# BNR Exchange Rate API
BNR_API_URL=https://www.bnr.ro/nbrfxrates.xml

# --- Web (apps/web) ---
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=schimba-asta-cu-openssl-rand-base64-32

# Sentry (opțional în dev)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
